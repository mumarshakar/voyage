  // ============================================
  // QUESTIONNAIRE FORM FOR SESAMI BOOKING
  // ============================================
  
  // Global variables to prevent multiple initializations
  let questionnaireInitialized = false;
  let submitBtnHandler = null;
  
  // Function to save questionnaire to cart attributes (defined outside so it's always available)
  function saveQuestionnaireToCart() {
    const questionnaireForm = document.getElementById('customer-questionnaire-form');
    if (!questionnaireForm) {
      console.error('Questionnaire form not found for saving');
      return Promise.reject(new Error('Form not found'));
    }
    
    const attributes = {};
    
    // Collect all input data manually (since we're using a div, not a form)
    const inputs = questionnaireForm.querySelectorAll('input, select, textarea');
    inputs.forEach(function(input) {
      const name = input.name;
      const value = input.value;
      if (name && value && value.trim() !== '') {
        attributes[name] = value.trim();
      }
    });
    
    // Update cart attributes via Shopify Cart API
    // Use /cart/update.js endpoint for JSON response
    return fetch('/cart/update.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify({
        attributes: attributes
      })
    })
    .then(response => {
      // Check if response is OK
      if (!response.ok) {
        // Try to get error message from response
        return response.text().then(text => {
          console.error('Cart update failed:', response.status, text);
          throw new Error(`Cart update failed: ${response.status}`);
        });
      }
      // Check content type to ensure it's JSON
      const contentType = response.headers.get('content-type');
      if (!contentType || !contentType.includes('application/json')) {
        return response.text().then(text => {
          console.error('Response is not JSON:', text.substring(0, 200));
          throw new Error('Server returned non-JSON response');
        });
      }
      return response.json();
    })
    .then(data => {
      console.log('✓ Questionnaire saved to cart attributes:', data);
      return data;
    })
    .catch((error) => {
      console.error('Error saving questionnaire:', error);
      throw error;
    });
  }
  
  // Handle questionnaire form submission (defined outside so it's always available)
  function createSubmitHandler() {
    return function(e) {
      e.preventDefault();
      e.stopPropagation();
      
      console.log('Continue to Booking button clicked');
      
      // Get fresh references in case DOM changed
      const currentForm = document.getElementById('customer-questionnaire-form');
      const currentBtn = document.getElementById('submit-questionnaire-btn');
      
      if (!currentForm || !currentBtn) {
        console.error('Form or button not found');
        return;
      }
      
      // Validate form - manually check required fields since we're using a div, not a form
      let isValid = true;
      const requiredFields = currentForm.querySelectorAll('[required]');
      requiredFields.forEach(function(field) {
        if (!field.value || field.value.trim() === '') {
          isValid = false;
          field.classList.add('is-invalid');
        } else {
          field.classList.remove('is-invalid');
          field.classList.add('is-valid');
        }
      });
      
      if (!isValid) {
        console.log('Form validation failed');
        currentForm.classList.add('was-validated');
        return false;
      }
      
      console.log('Form is valid, saving questionnaire...');
      
      // Disable submit button and show loading
      currentBtn.disabled = true;
      currentBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Saving...';
      
      // Save questionnaire data
      saveQuestionnaireToCart()
        .then(() => {
          console.log('✓ Questionnaire saved successfully');
          
          // Mark questionnaire as completed
          sessionStorage.setItem('questionnaire_completed', 'true');
          
          // Hide questionnaire card and show Sesami component
          const questionnaireCard = document.getElementById('customer-questionnaire-card');
          if (questionnaireCard) {
            questionnaireCard.style.display = 'none';
          }
          
          const sesamiCard = document.getElementById('sesami-booking-card');
          if (sesamiCard) {
            sesamiCard.style.display = 'block';
            console.log('✓ Questionnaire completed - Sesami component now visible');
          }
          
          // Re-run detection to update UI
          setTimeout(function() {
            detectAndShowButtons();
          }, 300);
        })
        .catch((error) => {
          console.error('Error saving questionnaire:', error);
          alert('There was an error saving your information. Please try again.');
          if (currentBtn) {
            currentBtn.disabled = false;
            currentBtn.innerHTML = '<i class="bi bi-check-circle me-2"></i>Continue to Booking';
          }
        });
    };
  }
  
  // Function to setup questionnaire form
  function setupQuestionnaireForm() {
    // Debug: Check if elements exist in DOM
    const questionnaireCard = document.getElementById('customer-questionnaire-card');
    const questionnaireForm = document.getElementById('customer-questionnaire-form');
    const submitBtn = document.getElementById('submit-questionnaire-btn');
    
    // Debug logging
    if (!questionnaireInitialized) {
