      const allergySelect = document.getElementById('customer_allergies');
      const foodSelect = document.getElementById('customer_food_availability');
      const allergyDetailsWrapper = document.getElementById('allergy-details-wrapper');
      const foodDetailsWrapper = document.getElementById('food-details-wrapper');
      
      // Show/hide allergy details based on selection
      if (allergySelect && allergyDetailsWrapper) {
        function toggleAllergyDetails() {
          if (allergySelect.value === 'Other') {
            allergyDetailsWrapper.style.display = 'block';
            const allergyDetailsInput = document.getElementById('customer_allergy_details');
            if (allergyDetailsInput) {
              allergyDetailsInput.setAttribute('required', 'required');
            }
          } else {
            allergyDetailsWrapper.style.display = 'none';
            const allergyDetailsInput = document.getElementById('customer_allergy_details');
            if (allergyDetailsInput) {
              allergyDetailsInput.removeAttribute('required');
            }
          }
        }
        allergySelect.addEventListener('change', toggleAllergyDetails);
        toggleAllergyDetails(); // Check on load
      }
      
      // Show/hide food details based on selection
      if (foodSelect && foodDetailsWrapper) {
        function toggleFoodDetails() {
          if (foodSelect.value === 'Other') {
            foodDetailsWrapper.style.display = 'block';
            const foodDetailsInput = document.getElementById('customer_food_details');
            if (foodDetailsInput) {
              foodDetailsInput.setAttribute('required', 'required');
            }
          } else {
            foodDetailsWrapper.style.display = 'none';
            const foodDetailsInput = document.getElementById('customer_food_details');
            if (foodDetailsInput) {
              foodDetailsInput.removeAttribute('required');
            }
          }
        }
        foodSelect.addEventListener('change', toggleFoodDetails);
        toggleFoodDetails(); // Check on load
      }
      
      questionnaireInitialized = true;
    }
    
    // Always ensure event listener is attached (even if already initialized)
    // Remove old listener if exists
    if (submitBtnHandler && submitBtn) {
      submitBtn.removeEventListener('click', submitBtnHandler);
    }
    
    // Create and attach new handler
    submitBtnHandler = createSubmitHandler();
    submitBtn.addEventListener('click', submitBtnHandler);
    console.log('✓ Event listener attached to submit button');
    
    return true; // Return true to indicate success
  }
  
  // Call setup when page is ready (but don't spam if elements don't exist)
  function initQuestionnaireForm() {
    setupQuestionnaireForm();
  }
  
  // Watch for questionnaire card to be added to DOM
  if (typeof MutationObserver !== 'undefined') {
    const questionnaireObserver = new MutationObserver(function(mutations) {
