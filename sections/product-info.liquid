    if (!questionnaireForm || !submitBtn) {
      // Don't log every time - only log if we haven't initialized yet
      if (!questionnaireInitialized) {
        console.log('Questionnaire form or button not found, will retry...');
        // Try to find why - check if card exists but form doesn't
        if (questionnaireCard && !questionnaireForm) {
          console.warn('⚠️ Card exists but form not found - checking card content...');
          console.log('Card HTML:', questionnaireCard.innerHTML.substring(0, 200));
        }
      }
      return false; // Return false to indicate failure
    }
    
    // Setup toggle handlers for allergy and food details (only once)
    if (!questionnaireInitialized) {
