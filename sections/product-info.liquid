                    if (cart.items.length > 0) {
                      const lastItem = cart.items[cart.items.length - 1];
                      console.log('Last cart item properties:', lastItem.properties);
                      
                      if (!lastItem.properties || Object.keys(lastItem.properties).length === 0) {
