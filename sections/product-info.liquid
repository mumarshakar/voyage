  // Function to intercept Sesami button clicks and show questionnaire modal
  function setupQuestionnaireModal() {
    const sesamiCard = document.getElementById('sesami-booking-card');
    if (!sesamiCard || sesamiCard.style.display === 'none') {
      return; // Sesami not visible, don't set up modal
    }
    
    const questionnaireModal = new bootstrap.Modal(document.getElementById('customer-questionnaire-modal'), {
      backdrop: 'static',
      keyboard: false
    });
    
    const questionnaireForm = document.getElementById('customer-questionnaire-form');
    const submitBtn = document.getElementById('submit-questionnaire-btn');
    const allergySelect = document.getElementById('modal_customer_allergies');
    const foodSelect = document.getElementById('modal_customer_food_availability');
    const allergyDetailsWrapper = document.getElementById('modal-allergy-details-wrapper');
    const foodDetailsWrapper = document.getElementById('modal-food-details-wrapper');
    
    // Show/hide allergy details based on selection
    if (allergySelect && allergyDetailsWrapper) {
      function toggleAllergyDetails() {
        if (allergySelect.value === 'Other') {
          allergyDetailsWrapper.style.display = 'block';
          const allergyDetailsInput = document.getElementById('modal_customer_allergy_details');
          if (allergyDetailsInput) {
            allergyDetailsInput.setAttribute('required', 'required');
          }
        } else {
          allergyDetailsWrapper.style.display = 'none';
          const allergyDetailsInput = document.getElementById('modal_customer_allergy_details');
          if (allergyDetailsInput) {
            allergyDetailsInput.removeAttribute('required');
          }
        }
      }
      allergySelect.addEventListener('change', toggleAllergyDetails);
      toggleAllergyDetails(); // Check on load
    }
    
    // Show/hide food details based on selection
    if (foodSelect && foodDetailsWrapper) {
      function toggleFoodDetails() {
        if (foodSelect.value === 'Other') {
          foodDetailsWrapper.style.display = 'block';
          const foodDetailsInput = document.getElementById('modal_customer_food_details');
          if (foodDetailsInput) {
            foodDetailsInput.setAttribute('required', 'required');
          }
        } else {
          foodDetailsWrapper.style.display = 'none';
          const foodDetailsInput = document.getElementById('modal_customer_food_details');
          if (foodDetailsInput) {
            foodDetailsInput.removeAttribute('required');
          }
        }
      }
      foodSelect.addEventListener('change', toggleFoodDetails);
      toggleFoodDetails(); // Check on load
    }
    
    // Function to save questionnaire to cart attributes
    function saveQuestionnaireToCart() {
      if (!questionnaireForm) return Promise.resolve();
      
      const formData = new FormData(questionnaireForm);
      const attributes = {};
      
      // Collect all form data
      for (let [key, value] of formData.entries()) {
        if (value.trim() !== '') {
          attributes[key] = value.trim();
        }
      }
      
      // Update cart attributes via API
      return fetch('{{ routes.cart_update_url }}', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({
          attributes: attributes
        })
      })
      .then(response => response.json())
      .then(data => {
        console.log('✓ Questionnaire saved to cart attributes');
        return data;
      })
      .catch((error) => {
        console.error('Error saving questionnaire:', error);
        throw error;
      });
    }
    
    // Handle questionnaire form submission
    if (submitBtn) {
      submitBtn.addEventListener('click', function(e) {
        e.preventDefault();
        
        // Validate form
        if (questionnaireForm && !questionnaireForm.checkValidity()) {
          questionnaireForm.classList.add('was-validated');
          return false;
        }
        
        // Disable submit button and show loading
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Saving...';
        
        // Save questionnaire data
        saveQuestionnaireToCart()
          .then(() => {
            // Close modal
            questionnaireModal.hide();
            
            // Trigger Sesami button click after a short delay
            setTimeout(function() {
              if (sesamiButtonClickPending && originalSesamiButton) {
                console.log('Triggering Sesami button after questionnaire completion');
                // Click the original Sesami button
                originalSesamiButton.click();
                sesamiButtonClickPending = false;
                originalSesamiButton = null;
              }
            }, 500);
          })
          .catch((error) => {
            console.error('Error saving questionnaire:', error);
            alert('There was an error saving your information. Please try again.');
            submitBtn.disabled = false;
            submitBtn.innerHTML = '<i class="bi bi-check-circle me-2"></i>Continue to Booking';
          });
      });
    }
    
    // Intercept Sesami button clicks
    function interceptSesamiButton() {
      // Find Sesami button (it might be in shadow DOM or dynamically created)
      const sesamiContainer = document.getElementById('sesami-container');
      if (!sesamiContainer) return;
      
      // Use MutationObserver to watch for Sesami button
      const buttonObserver = new MutationObserver(function(mutations) {
        // Look for Sesami button
        const sesamiButton = sesamiContainer.querySelector('button.sesami-calendar, button[class*="sesami"], sesami-experience button');
        
        if (sesamiButton && !sesamiButton.hasAttribute('data-questionnaire-intercepted')) {
          sesamiButton.setAttribute('data-questionnaire-intercepted', 'true');
          
          // Store original click handler
          const originalClick = sesamiButton.onclick || function() {};
          
          // Intercept click
          sesamiButton.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            e.stopImmediatePropagation();
            
            console.log('Sesami button clicked - showing questionnaire modal');
            
            // Store button reference for later
            sesamiButtonClickPending = true;
            originalSesamiButton = sesamiButton;
            
            // Show questionnaire modal
            questionnaireModal.show();
            
            return false;
          }, true); // Use capture phase to intercept early
          
          console.log('✓ Sesami button intercepted for questionnaire');
        }
      });
      
      // Observe Sesami container for button changes
      buttonObserver.observe(sesamiContainer, {
        childList: true,
        subtree: true,
        attributes: false
      });
      
      // Also check immediately
      setTimeout(function() {
        const sesamiButton = sesamiContainer.querySelector('button.sesami-calendar, button[class*="sesami"], sesami-experience button');
        if (sesamiButton && !sesamiButton.hasAttribute('data-questionnaire-intercepted')) {
          sesamiButton.setAttribute('data-questionnaire-intercepted', 'true');
          sesamiButton.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            sesamiButtonClickPending = true;
            originalSesamiButton = sesamiButton;
            questionnaireModal.show();
            return false;
          }, true);
        }
      }, 1000);
      
      // Also use event delegation on the container
      sesamiContainer.addEventListener('click', function(e) {
        const target = e.target;
        // Check if click is on a Sesami button
        if (target && (
          target.classList.contains('sesami-calendar') ||
          target.closest('button.sesami-calendar') ||
          target.closest('sesami-experience')
        )) {
          // Check if this is the initial booking button (not a time slot selection)
          const buttonText = target.textContent || target.innerText || '';
          if (buttonText.includes('Book Now') || buttonText.includes('Book') || target.classList.contains('sesami-calendar')) {
            e.preventDefault();
            e.stopPropagation();
            sesamiButtonClickPending = true;
            originalSesamiButton = target.closest('button') || target;
            questionnaireModal.show();
            return false;
          }
        }
      }, true);
    }
    
    // Set up interception when Sesami is ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() {
        setTimeout(interceptSesamiButton, 1000);
        setTimeout(interceptSesamiButton, 3000);
      });
    } else {
      setTimeout(interceptSesamiButton, 1000);
      setTimeout(interceptSesamiButton, 3000);
    }
    
    // Also watch for Sesami container changes
    const containerObserver = new MutationObserver(function() {
      interceptSesamiButton();
    });
    
    const sesamiContainer = document.getElementById('sesami-container');
    if (sesamiContainer) {
      containerObserver.observe(sesamiContainer, {
        childList: true,
        subtree: true
      });
    }
  }
  
  // Call setup when Sesami is detected
